<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:DispatchTiger.Converters">

    <!-- Value Converters -->
    <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>

    <!-- Color Palette -->
    <Color x:Key="DarkBackground">#151515</Color>
    <Color x:Key="HeaderBackground">#1F1F1F</Color>
    <Color x:Key="PanelBackground">#202020</Color>
    <Color x:Key="CardBackground">#2B2B2B</Color>
    <Color x:Key="CardBorder">#3A3A3A</Color>
    <Color x:Key="AccentOrange">#F28C28</Color>
    <Color x:Key="StrongOrange">#FF9F1C</Color>
    <Color x:Key="LightText">#F5F5F5</Color>
    <Color x:Key="MutedText">#BDBDBD</Color>
    <Color x:Key="DangerRed">#FF5C35</Color>
    <Color x:Key="SuccessGreen">#4CAF50</Color>

    <!-- Solid Color Brushes -->
    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="#151515"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#202020"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#F28C28"/>
    <SolidColorBrush x:Key="StrongOrangeBrush" Color="#FF9F1C"/>
    <SolidColorBrush x:Key="LightTextBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="DangerRedBrush" Color="#FF5C35"/>
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="#4CAF50"/>

    <!-- Header Background Border -->
    <Style x:Key="HeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#1F1F1F"/>
        <Setter Property="BorderBrush" Value="#F28C28"/>
        <Setter Property="BorderThickness" Value="0,0,0,3"/>
    </Style>

    <!-- Header Title -->
    <Style x:Key="HeaderTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#F5F5F5"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Header Subtitle -->
    <Style x:Key="HeaderSubtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#BDBDBD"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Panel Header -->
    <Style x:Key="PanelHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#F28C28"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Background" Value="#1F1F1F"/>
    </Style>

    <!-- Left Panel Border -->
    <Style x:Key="LeftPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Margin" Value="16,16,0,16"/>
    </Style>

    <!-- Job Card Border -->
    <Style x:Key="JobCardBorder" TargetType="Border">
        <Setter Property="Background" Value="#2B2B2B"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Job Description Text -->
    <Style x:Key="JobDescription" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#F5F5F5"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- Job Subtext -->
    <Style x:Key="JobSubtext" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#BDBDBD"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Job Priority Badge -->
    <Style x:Key="JobPriority" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#F28C28"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

    <!-- Placeholder Text for Empty States -->
    <Style x:Key="PlaceholderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,20"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>

    <!-- Tab Button (Active/Selected) -->
    <Style x:Key="TabButtonActive" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#F28C28"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderThickness" Value="0,3,0,0"/>
        <Setter Property="BorderBrush" Value="#F28C28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tab Button (Inactive) -->
    <Style x:Key="TabButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#BDBDBD"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#F5F5F5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Truck Card Border -->
    <Style x:Key="TruckCardBorder" TargetType="Border">
        <Setter Property="Background" Value="#2B2B2B"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Truck ID Text -->
    <Style x:Key="TruckID" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#F28C28"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Truck Detail Text -->
    <Style x:Key="TruckDetail" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#BDBDBD"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- Badge Style -->
    <Style x:Key="BadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#F28C28"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- Badge Text -->
    <Style x:Key="BadgeText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#151515"/>
    </Style>

    <!-- Action Panel Border -->
    <Style x:Key="ActionPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="#202020"/>
        <Setter Property="BorderBrush" Value="#3A3A3A"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Assign Button (Enabled) -->
    <Style x:Key="AssignButton" TargetType="Button">
        <Setter Property="Background" Value="#F28C28"/>
        <Setter Property="Foreground" Value="#151515"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF9F1C"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Assign Button (Disabled) -->
    <Style x:Key="AssignButtonDisabled" TargetType="Button">
        <Setter Property="Background" Value="#3A3A3A"/>
        <Setter Property="Foreground" Value="#BDBDBD"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Cursor" Value="NotAllowed"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="IsEnabled" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Placeholder Text for Action Panel -->
    <Style x:Key="ActionPlaceholderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#BDBDBD"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Section Header in Action Panel -->
    <Style x:Key="ActionSectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#F28C28"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="0"/>
    </Style>


    <!-- ScrollBar Thumb Style - color only for improved contrast -->
    <Style x:Key="{x:Type Thumb}" TargetType="Thumb">
        <Setter Property="Background" Value="#4A4A4A"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#666666"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="#888888"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>






