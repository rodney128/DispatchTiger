<Window x:Class="DispatchTiger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DispatchTiger"
        xmlns:views="clr-namespace:DispatchTiger.Views"
        xmlns:conv="clr-namespace:DispatchTiger.Converters"
        mc:Ignorable="d"
        Title="Dispatch Tiger" 
        Height="700" 
        Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <conv:NullToCollapsedConverter  x:Key="NullToCollapsed"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:EqualityConverter         x:Key="EqualityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Branded Header with Tiger Icon -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <StackPanel Orientation="Horizontal" Margin="8,0,20,0" VerticalAlignment="Center">
                <!-- Tiger Image -->
                <Image 
                    Source="Assets/Images/tigerImage.png" 
                    Width="104"
                    Height="104"
                    Stretch="Uniform"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"/>
                <!-- Title and Subtitle Stack -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <!-- Title -->
                    <TextBlock 
                        Text="Dispatch Tiger" 
                        Style="{StaticResource HeaderTitle}"/>
                    <!-- Subtitle -->
                    <TextBlock 
                        Text="Simple dispatch board for trucks, jobs, and assignments." 
                        Style="{StaticResource HeaderSubtitle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Unassigned Jobs -->
            <Border Grid.Column="0" Style="{StaticResource LeftPanelBorder}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Unassigned Jobs" Style="{StaticResource PanelHeader}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding UnassignedJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border 
                                        Name="JobBorder"
                                        MouseLeftButtonUp="JobBorder_MouseLeftButtonUp">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource JobCardBorder}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding Path="DataContext.SelectedJob"
                                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background"      Value="#303030"/>
                                                        <Setter Property="BorderBrush"     Value="#F28C28"/>
                                                        <Setter Property="BorderThickness" Value="3,1,1,1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource JobDescription}"/>
                                            <!-- Pickup: ShipperName — LocationName (shown when PickupLocation is set) -->
                                            <TextBlock Style="{StaticResource JobSubtext}" FontSize="11"
                                                       Visibility="{Binding PickupLocation, Converter={StaticResource NullToCollapsed}}">
                                                <Run Text="Pickup: "/><Run Text="{Binding Shipper.Name, Mode=OneWay}"/>
                                                <Run Text=" — "/><Run Text="{Binding PickupLocation.Name, Mode=OneWay}"/>
                                                <Run Text="{Binding PickupWindowStart, Mode=OneWay, StringFormat=' ({0:h:mm tt}'}"/>
                                                <Run Text="{Binding PickupWindowEnd,   Mode=OneWay, StringFormat='–{0:h:mm tt})'}"/>
                                            </TextBlock>
                                            <!-- Pickup address fallback (shown only when PickupLocation is null) -->
                                            <TextBlock Style="{StaticResource JobSubtext}"
                                                       Visibility="{Binding PickupLocation, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Run Text="Pickup:   "/><Run Text="{Binding PickupAddress, Mode=OneWay}"/>
                                                <Run Text="{Binding PickupWindowStart, Mode=OneWay, StringFormat=' ({0:h:mm tt}'}"/>
                                                <Run Text="{Binding PickupWindowEnd,   Mode=OneWay, StringFormat='–{0:h:mm tt})'}"/>
                                            </TextBlock>
                                            <!-- Delivery: ReceiverName — LocationName (shown when DeliveryLocation is set) -->
                                            <TextBlock Style="{StaticResource JobSubtext}" FontSize="11"
                                                       Visibility="{Binding DeliveryLocation, Converter={StaticResource NullToCollapsed}}">
                                                <Run Text="Delivery: "/><Run Text="{Binding Receiver.Name, Mode=OneWay}"/>
                                                <Run Text=" — "/><Run Text="{Binding DeliveryLocation.Name, Mode=OneWay}"/>
                                                <Run Text="{Binding DeliveryWindowStart, Mode=OneWay, StringFormat=' ({0:h:mm tt}'}"/>
                                                <Run Text="{Binding DeliveryWindowEnd,   Mode=OneWay, StringFormat='–{0:h:mm tt})'}"/>
                                            </TextBlock>
                                            <!-- Delivery address fallback (shown only when DeliveryLocation is null) -->
                                            <TextBlock Style="{StaticResource JobSubtext}"
                                                       Visibility="{Binding DeliveryLocation, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Run Text="Delivery: "/><Run Text="{Binding DeliveryAddress, Mode=OneWay}"/>
                                                <Run Text="{Binding DeliveryWindowStart, Mode=OneWay, StringFormat=' ({0:h:mm tt}'}"/>
                                                <Run Text="{Binding DeliveryWindowEnd,   Mode=OneWay, StringFormat='–{0:h:mm tt})'}"/>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource JobSubtext}"
                                                       Visibility="{Binding ScheduledDate, Converter={StaticResource NullToCollapsed}}">
                                                <Run Text="Sched:    "/>
                                                <Run Text="{Binding ScheduledDate, Mode=OneWay, StringFormat='{}{0:MM/dd}'}"/>
                                                <Run Text="{Binding ScheduledTime, Mode=OneWay, StringFormat=' @{0:D2}:00'}"/>
                                            </TextBlock>
                                            <TextBlock Style="{StaticResource JobPriority}">
                                                <Run Text="Priority: "/><Run Text="{Binding Priority, Mode=OneWay}"/>
                                            </TextBlock>
                                            <!-- Customer name — collapses when null -->
                                            <TextBlock Style="{StaticResource JobSubtext}" FontSize="11"
                                                       Visibility="{Binding Customer, Converter={StaticResource NullToCollapsed}}">
                                                <Run Text="Cust: "/><Run Text="{Binding Customer.Name, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right Area: Tabs + View Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Navigation Tabs (compact) -->
                <Border Grid.Row="0" Background="#1F1F1F" BorderThickness="0,1,0,1" BorderBrush="#3A3A3A">
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                        <!-- Day View Tab -->
                        <Button 
                            Name="DayViewTab"
                            Content="DAY VIEW"
                            Click="DayViewTab_Click"
                            Style="{StaticResource TabButtonActive}"
                            Padding="12,4"
                            Height="32"/>

                        <!-- Month View Tab -->
                        <Button 
                            Name="MonthViewTab"
                            Content="MONTH VIEW"
                            Click="MonthViewTab_Click"
                            Style="{StaticResource TabButton}"
                            Padding="12,4"
                            Height="32"
                            Margin="5,0,0,0"/>

                        <!-- Map View Tab -->
                        <Button
                            Name="MapViewTab"
                            Content="MAP VIEW"
                            Click="MapViewTab_Click"
                            Style="{StaticResource TabButton}"
                            Padding="12,4"
                            Height="32"
                            Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- View Content -->
                <ContentControl Grid.Row="1" Name="ViewContent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </Grid>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#1A1A1A"
                BorderBrush="#3A3A3A"
                BorderThickness="0,1,0,0"
                Padding="10,0">
            <DockPanel LastChildFill="True">
                <!-- Left-to-right pulse items, docked so status can fill the rest -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <TextBlock Text="DispatchTiger"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#F28C28"/>
                    <TextBlock Text=" | " FontSize="11" Foreground="#444444"/>
                    <TextBlock FontSize="11" Foreground="#888888">
                        <Run Text="{Binding CurrentView, StringFormat='{}{0} View'}"/>
                    </TextBlock>
                    <TextBlock Text=" | " FontSize="11" Foreground="#444444"/>
                    <TextBlock FontSize="11" Foreground="#888888">
                        <Run Text="Unassigned: "/><Run Text="{Binding UnassignedCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text=" | " FontSize="11" Foreground="#444444"/>
                    <TextBlock FontSize="11" Foreground="#888888">
                        <Run Text="Assigned: "/><Run Text="{Binding AssignedCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text=" | " FontSize="11" Foreground="#444444"/>
                    <TextBlock FontSize="11" Foreground="#888888">
                        <Run Text="Trucks: "/><Run Text="{Binding TruckCount, Mode=OneWay}"/>
                    </TextBlock>
                    <!-- Separator before status area -->
                    <TextBlock Text=" | " FontSize="11" Foreground="#444444"/>
                </StackPanel>
                <!-- Status message + inline Undo button fill remaining footer space -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                               FontSize="11"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Content="  Undo  "
                            Command="{Binding UndoCommand}"
                            FontSize="10"
                            Margin="10,0,0,0"
                            Padding="5,1"
                            Foreground="#F28C28"
                            Background="Transparent"
                            BorderBrush="#F28C28"
                            BorderThickness="1"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanUndo, Mode=OneWay}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>





