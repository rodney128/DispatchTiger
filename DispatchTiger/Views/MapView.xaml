<UserControl x:Class="DispatchTiger.Views.MapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#151515"
             Loaded="MapView_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: job context + refresh -->
        <Border Grid.Row="0" Background="#1F1F1F" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="10,4">
            <DockPanel LastChildFill="True">
                <Button Name="RefreshMapButton"
                        Content="⟳  Refresh Map"
                        Click="RefreshMapButton_Click"
                        DockPanel.Dock="Right"
                        Padding="10,3"
                        FontSize="12"
                        Foreground="#F28C28"
                        Background="Transparent"
                        BorderBrush="#F28C28"
                        BorderThickness="1"
                        Cursor="Hand"
                        VerticalAlignment="Center"/>
                <TextBlock Name="MapStatusText"
                           Text="Map View — Vancouver Island dispatch"
                           Foreground="#888888"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Map area: WebView2 fills all remaining space -->
        <wv2:WebView2 Grid.Row="1"
                      Name="MapWebView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

        <!-- Fallback: shown over the WebView2 when API key is missing -->
        <Border Grid.Row="1"
                Name="MissingKeyOverlay"
                Background="#1A1A1A"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                <TextBlock Text="🗺"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Google Maps API key missing"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#F28C28"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Set the GOOGLE_MAPS_API_KEY environment variable to enable the live map."
                           FontSize="13"
                           Foreground="#AAAAAA"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Truck locations and job pickup / delivery zones are still available via the Day View candidate panel."
                           FontSize="11"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
