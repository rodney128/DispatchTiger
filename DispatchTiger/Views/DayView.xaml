<UserControl x:Class="DispatchTiger.Views.DayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:DispatchTiger.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource DarkBackgroundBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Center: Dispatch Schedule Board (Time and Trucks Grid) -->
        <Border Grid.Row="0" Name="DispatchContentContainer" Background="{StaticResource PanelBackgroundBrush}" RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="DispatchContentScaleTransform" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Outer ScrollViewer: horizontal scrolling only — moves header and body together -->
                <ScrollViewer Grid.Row="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Truck Headers Row — columns and labels built in BuildScheduleGrid() -->
                        <Grid Name="TruckHeaderGrid" Grid.Row="0" Background="#202020" Margin="0,0,0,1" Height="80"/>

                        <!-- Inner ScrollViewer: vertical scrolling only — scrolls time rows under the fixed header -->
                        <ScrollViewer Grid.Row="1"
                                      Name="CenterDispatchScrollViewer"
                                      VerticalScrollBarVisibility="Visible"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <Grid VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Grid Name="ScheduleGrid" Background="{StaticResource PanelBackgroundBrush}" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                                <Canvas Name="CurrentTimeMarkerCanvas" IsHitTestVisible="False" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

            <!-- Truck Candidate Comparison Panel — shown when an unassigned job is selected -->
            <Border Grid.Row="1" x:Name="CandidatePanelBorder"
                    Background="#1C1C1C"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,1,0,0"
                    MinHeight="160"
                    Visibility="Collapsed">
                <Grid Margin="8,4,8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Job summary line (populated by BuildCandidatePanel in code-behind) -->
                    <StackPanel x:Name="CandidateJobSummaryPanel" Grid.Row="0"
                                Orientation="Horizontal" Margin="0,0,0,3"/>

                    <!-- Recommendation summary bar (populated by BuildCandidatePanel in code-behind) -->
                    <Border x:Name="CandidateRecommendationBar" Grid.Row="1"
                            Background="#222222" CornerRadius="2"
                            Padding="6,3" Margin="0,0,0,3"
                            Visibility="Collapsed">
                        <StackPanel x:Name="CandidateRecommendationContent" Orientation="Horizontal"/>
                    </Border>

                    <!-- Action bar: Assign staged truck button (populated by BuildCandidatePanel) -->
                    <StackPanel x:Name="CandidateActionBar" Grid.Row="2"
                                Orientation="Horizontal" Margin="0,0,0,3"/>

                    <!-- Column headers -->
                    <Border Grid.Row="3" Background="#252525" Padding="4,2" Margin="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Truck"     FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="1" Text="Driver"    FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="2" Text="Type"      FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="3" Text="Status"    FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="4" Text="Equipment" FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="5" Text="Time Fit"  FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="6" Text="Route Fit" FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="7" Text="Fit"       FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                            <TextBlock Grid.Column="8" Text="Reason"    FontSize="11" FontWeight="SemiBold" Foreground="#888888"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable candidate rows (populated by BuildCandidatePanel in code-behind) -->
                    <ScrollViewer Grid.Row="4" MaxHeight="180"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="CandidateRowsPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </UserControl>
